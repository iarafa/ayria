# AYRIA - .env.example

# Banco
POSTGRES_USER=ayria
POSTGRES_PASSWORD=***
POSTGRES_DB=ayria
POSTGRES_PORT=5432

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# Backend
BACKEND_PORT=8000
JWT_SECRET=***
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://192.168.3.37:5173,http://localhost:4173

# IA (MiniMax - OpenAI compatible)
AI_API_KEY=***
AI_BASE_URL=https://api.minimax.io/v1
AI_MODEL=MiniMax-M2.7

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure Blob Storage (oficial do dicionário de funções)
AZURE_STORAGE_SAS_URL=https://YOURACCOUNT.blob.core.windows.net/ayria?sp=racwdl&st=...&se=...&sr=c&sig=...
AZURE_STORAGE_CONTAINER=ayria
AZURE_STORAGE_LOCAL_FALLBACK=false
